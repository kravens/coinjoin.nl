import { Theme } from "@ui/theme.slint";

// Where the user is in the coinjoin flow: Request -> Approve -> Sign -> Done.
// Sets expectations per screen — the only interactive step is Approve; Sign
// runs unattended. Current step green, done steps dimmed green, rest muted.
export component CjStepper {
    in property <int> current: 0;

    height: 34px;

    HorizontalLayout {
        spacing: 8px;
        for label[i] in ["Request", "Approve", "Sign", "Done"]: VerticalLayout {
            spacing: 6px;
            horizontal-stretch: 1;
            Text {
                text: label;
                font-family: "Montserrat";
                font-size: 11px;
                font-weight: i == root.current ? 700 : 600;
                color: i == root.current ? Theme.palette-primary
                    : i < root.current ? Theme.palette-foreground
                    : Theme.palette-muted;
                horizontal-alignment: center;
            }
            Rectangle {
                height: 3px;
                border-radius: 2px;
                background: i <= root.current ? Theme.palette-primary : Theme.palette-border;
                opacity: i < root.current ? 0.4 : 1;
            }
        }
    }
}
