import { Theme, UISize } from "@ui/theme.slint";
import { CjButton } from "../../cjbutton.slint";
import { CjStepper } from "../../cjstepper.slint";
import { Card } from "@ui/card.slint";
import { SlideToConfirm } from "@ui/slide_to_confirm.slint";
import { Navigate } from "../../gen/navigate.slint";
import { Cj } from "../../cj.slint";

export component AuthorizePage inherits Rectangle {
    background: Theme.palette-background;
    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 24px + UISize.control-center-status-bar-height;
        padding-bottom: 24px;
        spacing: 12px;
        Text {
            text: "Authorize coinjoin?";
            color: Theme.palette-foreground;
            font-family: "Montserrat";
            font-size: 22px;
            font-weight: 700;
            horizontal-alignment: center;
        }
        CjStepper { current: 1; }
        Card {
            width: 100%;
            vertical-stretch: 0;
            size: lg;
            eyebrow: "Coordinator";
            title: "coinjoin.nl";
            body: "Account #0 (mainnet)\nMax fee: 1000 sat / round\nRounds: up to 10\nValid for: 12 hours\nOutputs: your wallet only";
            footer: "Then rounds sign automatically.";
        }
        Rectangle { vertical-stretch: 1; }
        CjButton {
            width: 100%;
            secondary: true;
            text: "Deny";
            clicked => { Navigate.backward(); }
        }
        SlideToConfirm {
            width: 100%;
            vertical-stretch: 0;
            control-height: 64px;
            label: "Slide";
            hint: "Slide to authorize";
            confirmed-label: "Authorized";
            thumb-color: Theme.palette-primary;
            track-color: Theme.palette-surface;
            track-border-color: Theme.palette-border;
            activated => { Cj.authorize(); Navigate.session({ }); }
        }
    }
}
