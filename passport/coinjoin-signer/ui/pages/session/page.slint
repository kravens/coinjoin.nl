import { Theme, UISize } from "@ui/theme.slint";
import { CjButton } from "../../cjbutton.slint";
import { Card } from "@ui/card.slint";
import { Chip, ChipColor } from "@ui/chip.slint";
import { Navigate } from "../../gen/navigate.slint";
import { Cj } from "../../cj.slint";

export component SessionPage inherits Rectangle {
    background: Theme.palette-background;

    VerticalLayout {
        width: parent.width;
        height: parent.height;
        padding-left: 24px;
        padding-right: 24px;
        padding-top: 24px + UISize.control-center-status-bar-height;
        padding-bottom: 24px;
        spacing: 14px;
        Text {
            text: "Session active";
            color: Theme.palette-foreground;
            font-family: "Montserrat";
            font-size: 22px;
            font-weight: 700;
            horizontal-alignment: center;
        }
        HorizontalLayout {
            alignment: center;
            Chip { text: "Signing for coinjoin.nl"; color: ChipColor.success; }
        }
        Text {
            text: "Rounds signed: " + Cj.rounds + " / " + Cj.max-rounds;
            color: Theme.palette-foreground;
            font-family: "Montserrat";
            font-size: 15px;
            font-weight: 600;
            horizontal-alignment: center;
        }
        Rectangle {
            width: 100%;
            height: 10px;
            border-radius: 5px;
            background: Theme.palette-border;
            Rectangle {
                x: 0;
                y: 0;
                height: parent.height;
                width: parent.width * (Cj.rounds / Cj.max-rounds);
                border-radius: 5px;
                background: Theme.palette-primary;
            }
        }
        Card {
            width: 100%;
            size: md;
            eyebrow: "Last round";
            title: Cj.rounds == 0 ? "Awaiting first round" : "Round " + Cj.rounds + " signed";
            body: Cj.rounds == 0
                ? "Ownership proofs and signatures are produced automatically as rounds arrive."
                : (Cj.last-result == ""
                    ? "Ownership proof sent, own inputs signed, fee within cap."
                    : Cj.last-result);
        }
        Rectangle { vertical-stretch: 1; }
        CjButton {
            width: 100%;
            text: Cj.rounds >= Cj.max-rounds ? "View summary" : "Simulate round";
            clicked => {
                if (Cj.rounds >= Cj.max-rounds) {
                    Navigate.complete({ });
                } else {
                    Cj.simulate-round();
                }
            }
        }
        CjButton {
            width: 100%;
            secondary: true;
            text: "Revoke session";
            clicked => { Cj.revoke(); Navigate.backward(); }
        }
    }
}
